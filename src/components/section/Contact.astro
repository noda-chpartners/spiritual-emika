---
import { Icon } from 'astro-icon/components';
---
<section class="section contact" id="contact">
  <div class="inner">
    <h2 class="contact-title">お問い合わせ</h2>
    <p class="contact-lead">
      ご予約・ご相談はお気軽にどうぞ。<br />
      下記よりご都合のよい方法をお選びください。
    </p>
    <div class="contact-grid">

      <!-- 予約フォーム -->
      <a
        class="contact-card primary"
        href="https://ssl.form-mailer.jp/fms/2fc037a7379554"
        target="_blank"
        rel="noopener noreferrer"
      >
        <Icon class="contact-card-icon" name="simple-icons:googleforms" />
        <span class="contact-card-label">予約フォーム</span>
        <span class="contact-card-note">24時間受付</span>
      </a>

      <!-- 電話 -->
      <a class="contact-card" href="tel:09017862822">
        <Icon class="contact-card-icon" name="mdi:phone" />
        <span class="contact-card-label">お電話</span>
        <span class="contact-card-value">090-1786-2822</span>
      </a>

      <!-- LINE -->
      <a
        class="contact-card"
        href="https://lin.ee/RnlnYGy"
        target="_blank"
        rel="noopener noreferrer"
      >
        <Icon class="contact-card-icon" name="simple-icons:line" />
        <span class="contact-card-label">LINE</span>
        <span class="contact-card-note">お気軽にメッセージを</span>
      </a>

      <!-- Instagram -->
      <a
        class="contact-card"
        href="https://www.instagram.com/emika_kamioroshi?igsh=MWJkZ2JscmRwMXJ5Yw%3D%3D&utm_source=qr"
        target="_blank"
        rel="noopener noreferrer"
      >
        <Icon class="contact-card-icon" name="simple-icons:instagram" />
        <span class="contact-card-label">Instagram</span>
        <span class="contact-card-note">DMでもご相談受付中</span>
      </a>

    </div>
  </div>
</section>

<style lang="scss">
  @use "../../styles/variables" as *;
  @use "../../styles/mixins" as *;

  .contact-title {
    text-align: center;
    font-size: clamp(1.6rem, 5vw, 2rem);
    color: #5c4d2a;
    margin-bottom: 16px;
  }

  .contact-lead {
    text-align: center;
    font-size: 0.95rem;
    color: #6b5b2e;
    line-height: 2;
    margin-bottom: 48px;

    @include sp {
      font-size: 0.875rem;
    }
  }

  .contact-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 20px;
    max-width: 860px;
    margin: 0 auto;

    @include tb {
      grid-template-columns: repeat(2, 1fr);
    }

    @include sp {
      grid-template-columns: 1fr;
      max-width: 360px;
    }
  }

  .contact-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    padding: 32px 16px;
    background-color: rgba(255, 255, 255, 0.65);
    border: 1px solid rgba(160, 140, 80, 0.35);
    border-radius: 16px;
    text-align: center;
    transition: background-color 0.2s, transform 0.2s, box-shadow 0.2s;

    &:hover {
      background-color: rgba(255, 255, 255, 0.9);
      transform: translateY(-4px);
      box-shadow: 0 8px 24px rgba(160, 140, 80, 0.15);
    }

    &.primary {
      background-color: rgba(201, 168, 76, 0.15);
      border-color: rgba(201, 168, 76, 0.6);

      &:hover {
        background-color: rgba(201, 168, 76, 0.28);
      }
    }
  }

  // global の img スタイルが当たらないよう svg に直接指定
  .contact-card-icon {
    width: 2rem;
    height: 2rem;
    color: #8a6d22;
    // global の img { width:100%; height:100% } はsvgに効かないが念のため
    flex-shrink: 0;
  }

  .contact-card-label {
    font-size: 1rem;
    color: #5c4d2a;
    letter-spacing: 0.05em;
  }

  .contact-card-value {
    font-size: 0.9rem;
    color: #3a2e1a;
    letter-spacing: 0.05em;
  }

  .contact-card-note {
    font-size: 0.7rem;
    color: #8a7d6b;
  }
</style>