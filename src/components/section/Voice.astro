---
import { Icon } from 'astro-icon/components';

const testimonials = [
  {
    text: "今日は鑑定ありがとうございました。名前と生年月日のみ伝えただけでぱっぱと早い鑑定でしかも当たってて聞きたい事を伝えると降りて来たメッセージを伝えてくれてまさしくって感じで納得でした。\n言われた事を頭において過ごしてみます。より良い未来になる様願いながら。\n感謝",
  },
  {
    text: "○○の件ですが、何も語らずとも傍にいない方がいいと言われ間違いないなと驚きました。\n自分でやってイケる自信を持つと教えて頂きブレない軸をしっかり持ちいけ行けるのだと感じました。",
  },
  {
    text: "鑑定をお願いしたのは二回目です。\nこちらの悩みに対して、必要な情報をお伝えいただけるので、モヤモヤと悩んでいた自分にとっては大変参考になりました。\n切り替えを考える時期も教えていただけたため、自分のターニングポイントを見逃さないように頑張れそうです。ありがとうございました。",
  },
  {
    text: "わかっていても言葉で言ってもらってやっぱりそうなんだと納得する所もありました。\n鑑定はやはり今の職場は合わないですね。😭\nわかってましたが続けれるアドバイスをと思ってましたが無理でした。😱\n資格を取ったら前向きに仕事探していこうと考えてます。\n（時間かかりそうですが、、笑笑）\n職場の人間関係、〇○さんの事も色々聞いてアドバイスを頂きありがとうございます。",
  },
];
---
<section class="section voice" id="voice">
  <div class="inner">
    <h2 class="voice-title">お客様の声</h2>
    <p class="voice-lead">
      鑑定をご利用いただいたお客様より、<br />
      お寄せいただいたお声をご紹介します。
    </p>

    <div class="voice-carousel">
      <button class="voice-arrow voice-arrow--prev" id="voicePrev" type="button" aria-label="前の声を見る">
        <Icon name="mdi:chevron-left" />
      </button>

      <ul class="voice-track" id="voiceTrack">
        {testimonials.map((t) => (
          <li class="voice-card">
            <span class="voice-quote" aria-hidden="true">“</span>
            <p class="voice-text">{t.text}</p>
            <p class="voice-meta">お客様より</p>
          </li>
        ))}
      </ul>

      <button class="voice-arrow voice-arrow--next" id="voiceNext" type="button" aria-label="次の声を見る">
        <Icon name="mdi:chevron-right" />
      </button>
    </div>

    <div class="voice-dots" id="voiceDots" role="tablist" aria-label="お客様の声の切り替え"></div>
  </div>
</section>

<style lang="scss">
  @use "../../styles/variables" as *;
  @use "../../styles/mixins" as *;

  .voice-title {
    text-align: center;
    font-size: clamp(1.6rem, 5vw, 2rem);
    color: #5c4d2a;
  }

  .voice-lead {
    text-align: center;
    font-size: 0.95rem;
    color: #6b5b2e;
    line-height: 2;
    margin-top: 16px;

    @include sp {
      font-size: 0.875rem;
    }
  }

  .voice-carousel {
    position: relative;
    display: flex;
    align-items: center;
    gap: 12px;
    max-width: 1000px;
    margin: 48px auto 0;
  }

  .voice-track {
    flex: 1;
    display: flex;
    gap: 24px;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    padding: 12px 4px 28px;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;

    &::-webkit-scrollbar {
      display: none;
    }
  }

  .voice-card {
    flex: 0 0 auto;
    width: min(420px, 80vw);
    scroll-snap-align: center;
    display: flex;
    flex-direction: column;
    padding: 32px 28px;
    background-color: rgba(255, 255, 255, 0.7);
    border: 1px solid rgba(160, 140, 80, 0.35);
    border-radius: 20px;
    box-shadow: 0 6px 18px rgba(160, 140, 80, 0.08);
  }

  .voice-quote {
    font-family: serif;
    font-size: 3rem;
    line-height: 0.6;
    color: rgba(201, 168, 76, 0.55);
    margin-bottom: 12px;
  }

  .voice-text {
    flex: 1;
    white-space: pre-line;
    font-size: 0.92rem;
    line-height: 2;
    color: #5c4d2a;

    @include sp {
      font-size: 0.85rem;
    }
  }

  .voice-meta {
    margin-top: 20px;
    text-align: right;
    font-size: 0.8rem;
    color: #8a6d22;
    letter-spacing: 0.08em;

    &::before {
      content: '— ';
    }
  }

  .voice-arrow {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    border-radius: 50%;
    border: 1px solid rgba(160, 140, 80, 0.4);
    background-color: rgba(255, 255, 255, 0.8);
    color: #8a6d22;
    transition: background-color 0.2s, color 0.2s, transform 0.2s;

    svg {
      width: 22px;
      height: 22px;
    }

    &:hover {
      background-color: rgba(201, 168, 76, 0.2);
      color: #c9a84c;
      transform: scale(1.05);
    }

    @include sp {
      display: none; // モバイルはスワイプ操作
    }
  }

  .voice-dots {
    display: flex;
    justify-content: center;
    gap: 10px;
    margin-top: 4px;
  }

  // ↓ ドットは JS で生成
  :global(.voice-dot) {
    width: 9px;
    height: 9px;
    border-radius: 50%;
    border: 1px solid rgba(160, 140, 80, 0.5);
    background-color: transparent;
    cursor: pointer;
    transition: background-color 0.2s, transform 0.2s;

    &.is-active {
      background-color: #c9a84c;
      border-color: #c9a84c;
      transform: scale(1.2);
    }
  }
</style>

<script>
  const carousel = document.querySelector('.voice-carousel');

  if (carousel) {
    const track = document.getElementById('voiceTrack') as HTMLElement;
    const cards = Array.from(track.querySelectorAll<HTMLElement>('.voice-card'));
    const prevBtn = document.getElementById('voicePrev') as HTMLButtonElement;
    const nextBtn = document.getElementById('voiceNext') as HTMLButtonElement;
    const dotsWrap = document.getElementById('voiceDots') as HTMLElement;

    let current = 0;

    // ── ドット生成 ──
    cards.forEach((_, i) => {
      const dot = document.createElement('button');
      dot.type = 'button';
      dot.className = 'voice-dot';
      dot.setAttribute('role', 'tab');
      dot.setAttribute('aria-label', `${i + 1}番目の声`);
      dot.addEventListener('click', () => goTo(i));
      dotsWrap.appendChild(dot);
    });
    const dots = Array.from(dotsWrap.children) as HTMLElement[];

    const centerOf = (card: HTMLElement) => card.offsetLeft + card.offsetWidth / 2;

    function goTo(index: number) {
      current = Math.max(0, Math.min(cards.length - 1, index));
      const left = centerOf(cards[current]) - track.clientWidth / 2;
      track.scrollTo({ left, behavior: 'smooth' });
    }

    function updateActive() {
      const viewCenter = track.scrollLeft + track.clientWidth / 2;
      let closest = 0;
      let min = Infinity;
      cards.forEach((card, i) => {
        const d = Math.abs(centerOf(card) - viewCenter);
        if (d < min) {
          min = d;
          closest = i;
        }
      });
      current = closest;
      dots.forEach((dot, i) => dot.classList.toggle('is-active', i === closest));
    }

    prevBtn.addEventListener('click', () => goTo(current - 1));
    nextBtn.addEventListener('click', () => goTo(current + 1));

    let ticking = false;
    track.addEventListener('scroll', () => {
      if (!ticking) {
        window.requestAnimationFrame(() => {
          updateActive();
          ticking = false;
        });
        ticking = true;
      }
    });
    window.addEventListener('resize', updateActive);
    updateActive();

    // ── 自動再生（操作・ホバーで停止 / reduced-motion は無効） ──
    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (!reduce) {
      const advance = () => goTo(current >= cards.length - 1 ? 0 : current + 1);
      let timer = window.setInterval(advance, 5000);
      const stop = () => window.clearInterval(timer);
      const start = () => {
        stop();
        timer = window.setInterval(advance, 5000);
      };
      carousel.addEventListener('mouseenter', stop);
      carousel.addEventListener('mouseleave', start);
      track.addEventListener('pointerdown', stop);
      track.addEventListener('focusin', stop);
    }
  }
</script>