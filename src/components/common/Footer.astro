---
import { Icon } from 'astro-icon/components';
---
<footer class="footer">
  <div class="inner">
    <div class="footer-top">

      <div class="footer-info">
        <p class="footer-name">神降ろし鑑定江美香</p>
        <p class="footer-address">
          〒470-0162&ensp;愛知県愛知郡東郷町和合知々釜167-1
        </p>
        <a class="footer-tel" href="tel:09017862822">090-1786-2822</a>
      </div>

      <nav class="footer-nav">
        <ul class="footer-nav-list">
          <li><a href="#about" class="footer-nav-link">私について</a></li>
          <li><a href="#menu" class="footer-nav-link">鑑定料金 / メニュー</a></li>
          <li><a href="#info" class="footer-nav-link">基本情報</a></li>
          <li><a href="#contact" class="footer-nav-link">お問い合わせ</a></li>
        </ul>
      </nav>

      <div class="footer-sns">
        <p class="footer-sns-label">Follow us</p>
        <ul class="footer-sns-list">
          <li>
            <a
              class="footer-sns-link"
              href="https://www.instagram.com/アカウント名/"
              target="_blank"
              rel="noopener noreferrer"
              aria-label="Instagram"
            >
              <Icon name="simple-icons:instagram" />
            </a>
          </li>
          <li>
            <a
              class="footer-sns-link"
              href="https://lin.ee/xxxxxxx"
              target="_blank"
              rel="noopener noreferrer"
              aria-label="LINE"
            >
              <Icon name="simple-icons:line" />
            </a>
          </li>
        </ul>
      </div>

    </div>

    <div class="footer-bottom">
      <p class="footer-copy">
        &copy; {new Date().getFullYear()} 神降ろし鑑定エミカ All Rights Reserved.
      </p>
    </div>
  </div>
</footer>

<style lang="scss">
  @use "../../styles/variables" as *;
  @use "../../styles/mixins" as *;

  .footer {
    padding: 60px 20px 24px;
    border-top: 1px solid rgba(160, 140, 80, 0.3);
  }

  .footer-inner {
    display: flex;
    flex-direction: column;
    gap: 48px;
  }

  // ── 上段 ────────────────────────────────────────────
  .footer-top {
    display: grid;
    grid-template-columns: 1fr auto auto;
    gap: 48px;
    align-items: start;

    @include tb {
      grid-template-columns: 1fr 1fr;
    }

    @include sp {
      grid-template-columns: 1fr;
      gap: 32px;
    }
  }

  // ── 店舗情報 ─────────────────────────────────────────
  .footer-name {
    font-size: 1.1rem;
    color: #5c4d2a;
    margin-bottom: 8px;
    letter-spacing: 0.05em;
  }

  .footer-address {
    font-size: 0.8rem;
    color: #8a7d6b;
    line-height: 1.8;
    margin-bottom: 8px;
  }

  .footer-tel {
    font-size: 0.9rem;
    color: #8a6d22;
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-color: rgba(160, 140, 80, 0.5);

    &:hover {
      color: #c9a84c;
    }
  }

  // ── ナビ ─────────────────────────────────────────────
  .footer-nav-list {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .footer-nav-link {
    font-size: 0.85rem;
    color: #6b5b2e;
    letter-spacing: 0.05em;
    position: relative;

    &::after {
      content: '';
      position: absolute;
      bottom: -2px;
      left: 0;
      width: 0;
      height: 1px;
      background-color: #c9a84c;
      transition: width 0.25s ease;
    }

    &:hover::after {
      width: 100%;
    }
  }

  // ── SNS ──────────────────────────────────────────────
  .footer-sns-label {
    font-size: 0.75rem;
    color: #8a6d22;
    letter-spacing: 0.12em;
    margin-bottom: 12px;
  }

  .footer-sns-list {
    display: flex;
    gap: 16px;
  }

  .footer-sns-link {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border: 1px solid rgba(160, 140, 80, 0.4);
    border-radius: 50%;
    color: #8a6d22;
    transition: background-color 0.2s, color 0.2s;

    svg {
      width: 18px;
      height: 18px;
    }

    &:hover {
      background-color: rgba(201, 168, 76, 0.2);
      color: #c9a84c;
    }
  }

  // ── 下段（コピーライト）──────────────────────────────
  .footer-bottom {
    border-top: 1px solid rgba(160, 140, 80, 0.2);
    margin-top: 20px;
    padding-top: 20px;
    text-align: center;
  }

  .footer-copy {
    font-size: 0.75rem;
    color: #a89870;
    letter-spacing: 0.05em;
  }
</style>